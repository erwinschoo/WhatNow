# Build-time API-keys voor de catalogus-pipeline. Komen NIET in de app-bundle —
# de pipeline draait lokaal en schrijft alleen statische JSON weg.
# Kopieer naar .env en vul in.

# TMDB: gratis, registreer op https://www.themoviedb.org/settings/api (v3 API key)
TMDB_API_KEY=

# OMDb: gratis tier (1000/dag) op https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# Anthropic (Claude): voor feel-scores, thema's, trivia en quiz
ANTHROPIC_API_KEY=

# Optioneel: model-override (default claude-opus-4-8). Een goedkoper model kan
# voor deze classificatie-taak prima werken, bv. claude-haiku-4-5.
# WHATNOW_MODEL=claude-opus-4-8
